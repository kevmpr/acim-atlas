{
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://austral-sa.vercel.app https://austral-kevins-projects-94a9d818.vercel.app https://*.vercel.app"
        }
      ]
    }
  ]
}
